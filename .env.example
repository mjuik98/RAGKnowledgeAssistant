APP_NAME=Korean RAG Knowledge Assistant
APP_ENV=local
DB_PATH=storage/app.db
RAW_DIR=storage/raw
PARSED_DIR=storage/parsed
INDEX_DIR=storage/index
EVAL_REPORT_DIR=storage/evals

CHUNK_SIZE=700
CHUNK_OVERLAP=120
MIN_RETRIEVAL_SCORE=0.20

ENABLE_DENSE_RETRIEVAL=true
DENSE_BACKEND=hash
DENSE_MODEL_NAME=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
DENSE_EMBEDDING_DIM=384
EMBEDDING_BATCH_SIZE=32
EMBEDDING_CACHE_ENABLED=true
HYBRID_ALPHA=0.65
CANDIDATE_POOL_SIZE=20

GENERATOR_MODE=extractive
TOP_K_DEFAULT=5
